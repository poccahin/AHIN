# ============================================================
# Life++ Agent OS — Environment Configuration
# ============================================================
# Copy this file to .env and fill in real values.
# NEVER commit .env with real secrets.

# --- Application ---
APP_ENV=development
APP_SECRET_KEY=change-me-to-a-long-random-string
LOG_LEVEL=INFO

# --- Database ---
DATABASE_URL=postgresql+asyncpg://lifepp:lifepp@localhost:5432/lifepp
DATABASE_POOL_SIZE=10

# --- Redis (event bus, cache) ---
REDIS_URL=redis://localhost:6379/0

# --- Solana / LIFE++ Token ---
SOLANA_RPC_URL=https://api.mainnet-beta.solana.com
SOLANA_CLUSTER=mainnet-beta
LIFE_TOKEN_MINT_ADDRESS=<YOUR_LIFE_TOKEN_MINT_ADDRESS>
TREASURY_WALLET_PUBLIC_KEY=<YOUR_TREASURY_PUBKEY>
# Private key only used in the settlement worker — store in Vault in production
SETTLEMENT_WALLET_PRIVATE_KEY_B58=<BASE58_PRIVATE_KEY>

# --- AHIN Network ---
AHIN_NODE_ID=<YOUR_NODE_UUID>
AHIN_NETWORK_BOOTSTRAP_PEERS=peer1.ahin.local:8001,peer2.ahin.local:8001
AHIN_MIN_STAKE_USDT_EQUIVALENT=10.0
AHIN_MICRO_USAGE_USDT_EQUIVALENT=0.00001

# --- Participation threshold ---
# An agent must hold >= 10 USDT equivalent in LIFE++ to join AHIN
AHIN_ADMISSION_THRESHOLD_USDT=10.0

# --- Value flow ---
# min{LIFE++ equivalent of 0.00001 USDT, 1 LIFE++}
COLLABORATION_COST_USDT=0.00001
COLLABORATION_COST_MAX_LIFEPP=1.0

# --- Observability ---
OTEL_EXPORTER_OTLP_ENDPOINT=http://localhost:4317
OTEL_SERVICE_NAME=lifepp-agent-os

# --- Control Plane API ---
CONTROL_PLANE_HOST=0.0.0.0
CONTROL_PLANE_PORT=8000

# --- Edge Terminal ---
EDGE_TERMINAL_ID=<YOUR_EDGE_TERMINAL_UUID>
EDGE_OFFLINE_QUEUE_MAX_SIZE=10000
EDGE_SYNC_INTERVAL_SECONDS=300

# --- Settlement Worker ---
SETTLEMENT_BATCH_SIZE=500
DAY_CLOSE_UTC_HOUR=23
